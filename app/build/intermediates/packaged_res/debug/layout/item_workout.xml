<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Workout Name + Checkmark Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_workout_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Week 1: Gentle Awakening" />

            <TextView
                android:id="@+id/text_workout_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="@color/md_theme_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="25 min" />

            <ImageButton
                android:id="@+id/button_complete_workout"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mark workout complete"
                android:src="@android:drawable/checkbox_off_background"
                android:scaleType="centerInside"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Difficulty + Exercise Count Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_workout_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                tools:text="Very Easy" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/text_workout_focus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Focus: Full Body Activation" />

            <TextView
                android:id="@+id/text_exercise_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="3 exercises" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/text_workout_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            tools:text="A gentle reintroduction to movement." />

        <!-- Exercise Summary -->
        <TextView
            android:id="@+id/text_exercise_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            tools:text="• Walking — 1×10 minutes" />

        <!-- Modification Note -->
        <TextView
            android:id="@+id/text_modification_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/modification_background"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            tools:text="⚠️ If knee aches, reduce duration" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
