<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- English + Play Button Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_english"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Hello" />

            <ImageButton
                android:id="@+id/button_play_audio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/play_pronunciation"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/md_theme_primary" />
        </LinearLayout>

        <!-- Thai Script -->
        <TextView
            android:id="@+id/text_thai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/md_theme_primary"
            android:textSize="28sp"
            tools:text="สวัสดี" />

        <!-- Phonetic -->
        <TextView
            android:id="@+id/text_phonetic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/md_theme_secondary_variant"
            android:textSize="16sp"
            android:textStyle="italic"
            tools:text="sà-wàt-dee" />

        <!-- Category -->
        <TextView
            android:id="@+id/text_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@color/md_theme_primary"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Greetings" />

        <!-- Usage Example -->
        <TextView
            android:id="@+id/text_usage_example"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            tools:text="สวัสดีค่ะ (sà-wàt-dee kâ) — Hello (polite, female speaker)" />

        <!-- Mastered Button -->
        <TextView
            android:id="@+id/button_mastered_thai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="Mark Learned"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip_background"
            android:textColor="@android:color/white" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
